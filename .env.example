# ─────────────────────────────────────────────────────────────────────────────
# Fathom — environment. Copy to `.env.local` and fill what you have.
# EVERYTHING is optional: with nothing set, Fathom runs in "honest degrade" mode
# (real grounded script + procedural inked plate + real vision audit via the dev
# fallback if present; the moving-video step shows a labelled still preview).
# The moment a key exists, the matching real path activates — no code change.
# NEVER commit real keys. This file is the template only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Qwen Cloud (the production engine) ───────────────────────────────────────
# A plain DashScope `sk-` key. When set, Fathom drives the whole pipeline on
# Qwen Cloud (chat/vision/image/video/tts) at the international base URL.
DASHSCOPE_API_KEY=
# International (Singapore) endpoint — the international base URL.
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com

# ── Provider selection ───────────────────────────────────────────────────────
# auto (default): Qwen if DASHSCOPE_API_KEY is set, else the dev fallback below.
# Force with: qwen | anthropic
FATHOM_PROVIDER=auto

# ── Dev fallback (so the real orchestration runs without a Qwen key) ──────────
# Text / structured / vision only. Video + TTS still require Qwen (honest degrade).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Model ids (override only if you must; sensible defaults are built in) ─────
# Qwen crew:
FATHOM_MODEL_NAVIGATOR=qwen3.7-max
FATHOM_MODEL_CARTOGRAPHER=qwen3.7-plus
FATHOM_MODEL_ASSAYER=qwen3-vl-plus
FATHOM_MODEL_IMAGE=wan2.6-t2i
FATHOM_MODEL_VIDEO=wan2.7-r2v
FATHOM_MODEL_TTS=cosyvoice-v3-plus
# Anthropic fallback (any current Claude model with vision works):
FATHOM_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Video engine ─────────────────────────────────────────────────────────────
# The moving cutaways are the one thing that genuinely needs Qwen video-gen.
# Set to 1 to attempt real r2v jobs when DASHSCOPE_API_KEY is present.
FATHOM_VIDEO_ENABLED=1
# Free-tier video-second budget per voyage (a budget constraint, made a feature).
FATHOM_VIDEO_BUDGET_S=50

# ── Persistence — the Logbook ────────────────────────────────────────────────
# Default: a local filesystem store (survives restarts). Override the dir if you
# like. In production this can be a mounted disk on Alibaba Cloud ECS/SAS.
FATHOM_STORE_DIR=.fathom-store

# Optional Alibaba Cloud OSS object storage for the downloaded media. When set,
# rendered scenes/finished shorts are persisted to OSS instead of local disk.
ALIBABA_OSS_REGION=
ALIBABA_OSS_BUCKET=
ALIBABA_OSS_ACCESS_KEY_ID=
ALIBABA_OSS_ACCESS_KEY_SECRET=

# Optional external database (Postgres/etc.) for the structured Logbook records.
# When unset, records are kept as JSON in FATHOM_STORE_DIR.
DATABASE_URL=
