# ─────────────────────────────────────────────────────────────────────────────
# Fathom — environment. Copy to `.env.local` and fill what you have.
# EVERYTHING is optional: with nothing set, Fathom runs in "honest degrade" mode
# (real grounded script + procedural inked plate + real vision audit via the dev
# fallback if present; the moving-video step shows a labelled still preview).
# The moment a key exists, the matching real path activates — no code change.
# NEVER commit real keys. This file is the template only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Qwen Cloud (the production engine) ───────────────────────────────────────
# A plain DashScope `sk-` key. When set, Fathom drives the whole pipeline on
# Qwen Cloud (chat/vision/image/video/tts) at the international base URL.
DASHSCOPE_API_KEY=
# International (Singapore) endpoint — the international base URL.
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com

# ── Provider selection ───────────────────────────────────────────────────────
# auto (default): Qwen if DASHSCOPE_API_KEY is set, else the dev fallback below.
# Force with: qwen | anthropic
FATHOM_PROVIDER=auto

# ── Dev fallback (so the real orchestration runs without a Qwen key) ──────────
# Text / structured / vision only. Video + TTS still require Qwen (honest degrade).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Model ids (override only if you must; sensible defaults are built in) ─────
# Qwen crew:
FATHOM_MODEL_NAVIGATOR=qwen3.7-max
